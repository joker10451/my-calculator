# Cloudflare Pages HTTP Headers

# Безопасность для всех страниц
/*
  X-Content-Type-Options: nosniff
  X-Frame-Options: DENY
  X-XSS-Protection: 1; mode=block
  Referrer-Policy: strict-origin-when-cross-origin
  Permissions-Policy: camera=(), microphone=(), geolocation=()

# Статические ассеты — агрессивный кэш (1 год, immutable)
/assets/*
  Cache-Control: public, max-age=31536000, immutable
  Access-Control-Allow-Origin: *

# Шрифты
/*.woff2
  Cache-Control: public, max-age=31536000, immutable
  Access-Control-Allow-Origin: *

# Иконки (1 год)
/favicon.ico
  Cache-Control: public, max-age=31536000, immutable

/icon.svg
  Cache-Control: public, max-age=31536000, immutable

/icon-192.png
  Cache-Control: public, max-age=31536000, immutable

/icon-512.png
  Cache-Control: public, max-age=31536000, immutable

/apple-touch-icon.png
  Cache-Control: public, max-age=31536000, immutable

# Manifest и SW (1 день)
/manifest.json
  Cache-Control: public, max-age=86400

/sw.js
  Cache-Control: public, max-age=0, must-revalidate

# Sitemap и robots (1 день)
/sitemap.xml
  Cache-Control: public, max-age=86400

/robots.txt
  Cache-Control: public, max-age=86400

# HTML страницы — короткий кэш (10 минут) + revalidate
/index.html
  Cache-Control: public, max-age=600, stale-while-revalidate=3600

# Все остальные HTML (SPA routes)
/calculator/*
  Cache-Control: public, max-age=600, stale-while-revalidate=3600

/blog/*
  Cache-Control: public, max-age=600, stale-while-revalidate=3600

/calc/*
  Cache-Control: public, max-age=600, stale-while-revalidate=3600
